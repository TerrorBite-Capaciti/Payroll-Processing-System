000100 IDENTIFICATION DIVISION.
000200 PROGRAM-ID. TAXCALCULATION.
000300 AUTHOR.     Sisamkele Vava.
000400 DATE-WRITTEN. [Date].
000500
000600 ENVIRONMENT DIVISION.
000700 CONFIGURATION SECTION.
000800 SPECIAL-NAMES.
000900
001000 DATA DIVISION.
001100 WORKING-STORAGE SECTION.
001200 01  TAX-BRACKETS.
001300     05  TAX-BRACKET OCCURS 5 TIMES INDEXED BY TAX-INDEX.
001400         10  TB-LOWER-LIMIT    PIC 9(7)V99.
001500         10  TB-UPPER-LIMIT    PIC 9(7)V99.
001600         10  TB-BASE-TAX       PIC 9(7)V99.
001700         10  TB-RATE           PIC V9(3).
001800
001900 01  SOCIAL-SECURITY-RATES.
002000     05  SS-RATE              PIC V9(4) VALUE .0620.
002100     05  SS-WAGE-BASE         PIC 9(7)V99 VALUE 147000.00.
002200     05  MEDICARE-RATE        PIC V9(4) VALUE .0145.
002300     05  MEDICARE-ADD-RATE    PIC V9(4) VALUE .0090.
002400     05  MEDICARE-THRESHOLD   PIC 9(7)V99 VALUE 200000.00.
002500
002600 01  TAX-CONSTANTS.
002700     05  STANDARD-DEDUCTION   PIC 9(5)V99 VALUE 12950.00.
002800     05  DEPENDENT-CREDIT     PIC 9(4)V99 VALUE 500.00.
002900
003000 01  WS-TAXABLE-EARNINGS      PIC 9(7)V99.
003100
003200 LINKAGE SECTION.
003300 01  LS-TAX-PARAMS.
003400     05  LS-GROSS-PAY         PIC 9(7)V99.
003500     05  LS-TAX-CODE          PIC X(2).
003600     05  LS-MARITAL-STATUS    PIC X.
003700     05  LS-NUM-DEPENDENTS    PIC 99.
003800     05  LS-YTD-EARNINGS      PIC 9(8)V99.
003900     05  LS-TAX-AMOUNT        PIC 9(7)V99.
004000     05  LS-SS-AMOUNT         PIC 9(7)V99.
004100     05  LS-MEDICARE-AMOUNT   PIC 9(7)V99.
004200     05  LS-NET-TAX           PIC 9(7)V99.
004300     05  LS-ERROR-CODE        PIC XX.
004400
004500 PROCEDURE DIVISION USING LS-TAX-PARAMS.
004600 000-MAIN.
004700     PERFORM 100-INITIALIZE-TAX-TABLES
004800     PERFORM 200-VALIDATE-INPUTS
004900     IF LS-ERROR-CODE = '00'
005000         PERFORM 300-CALCULATE-INCOME-TAX
005100         PERFORM 400-CALCULATE-SOCIAL-SECURITY
005200         PERFORM 500-CALCULATE-MEDICARE
005300         PERFORM 600-CALCULATE-TOTAL-TAXES
005400     END-IF
005500     GOBACK.
005600
005700 100-INITIALIZE-TAX-TABLES.
005800     MOVE 0        TO TB-LOWER-LIMIT(1)
005900     MOVE 10275.00 TO TB-UPPER-LIMIT(1)
006000     MOVE 0        TO TB-BASE-TAX(1)
006100     MOVE .100     TO TB-RATE(1)
006200
006300     MOVE 10275.01 TO TB-LOWER-LIMIT(2)
006400     MOVE 41775.00 TO TB-UPPER-LIMIT(2)
006500     MOVE 1027.50  TO TB-BASE-TAX(2)
006600     MOVE .120     TO TB-RATE(2)
006700
006800     MOVE 41775.01 TO TB-LOWER-LIMIT(3)
006900     MOVE 89075.00 TO TB-UPPER-LIMIT(3)
007000     MOVE 4807.50  TO TB-BASE-TAX(3)
007100     MOVE .220     TO TB-RATE(3)
007200
007300     MOVE 89075.01 TO TB-LOWER-LIMIT(4)
007400     MOVE 170050.00 TO TB-UPPER-LIMIT(4)
007500     MOVE 15213.50 TO TB-BASE-TAX(4)
007600     MOVE .240     TO TB-RATE(4)
007700
007800     MOVE 170050.01 TO TB-LOWER-LIMIT(5)
007900     MOVE 9999999.99 TO TB-UPPER-LIMIT(5)
008000     MOVE 34647.50 TO TB-BASE-TAX(5)
008100     MOVE .320     TO TB-RATE(5).
008200
008300 200-VALIDATE-INPUTS.
008400     IF LS-TAX-CODE = 'T1' OR LS-TAX-CODE = 'T2'
008500         OR LS-TAX-CODE = 'T3' OR LS-TAX-CODE = 'T4'
008600         MOVE '00' TO LS-ERROR-CODE
008700     ELSE
008800         MOVE 'TC' TO LS-ERROR-CODE
008900     END-IF.
009000
009100 300-CALCULATE-INCOME-TAX.
009200     COMPUTE LS-GROSS-PAY = LS-GROSS-PAY - STANDARD-DEDUCTION
009300     IF LS-GROSS-PAY < 0
009400         MOVE 0 TO LS-GROSS-PAY
009500     END-IF
009600
009700     SET TAX-INDEX TO 1
009800     SEARCH TAX-BRACKET
009900         AT END
010000             MOVE 0 TO LS-TAX-AMOUNT
010100         WHEN LS-GROSS-PAY >= TB-LOWER-LIMIT(TAX-INDEX)
010200              AND LS-GROSS-PAY <= TB-UPPER-LIMIT(TAX-INDEX)
010300             COMPUTE LS-TAX-AMOUNT = 
010400                 TB-BASE-TAX(TAX-INDEX) + 
010500                 ((LS-GROSS-PAY - TB-LOWER-LIMIT(TAX-INDEX)) * 
010600                 TB-RATE(TAX-INDEX))
010700     END-SEARCH
010800
010900     IF LS-NUM-DEPENDENTS > 0
011000         COMPUTE LS-TAX-AMOUNT = LS-TAX-AMOUNT - 
011100                                   (LS-NUM-DEPENDENTS * DEPENDENT-CREDIT)
011200         IF LS-TAX-AMOUNT < 0
011300             MOVE 0 TO LS-TAX-AMOUNT
011400         END-IF
011500     END-IF.
011600
011700 400-CALCULATE-SOCIAL-SECURITY.
011800     IF LS-YTD-EARNINGS < SS-WAGE-BASE
011900         COMPUTE LS-SS-AMOUNT = 
012000             (SS-WAGE-BASE - LS-YTD-EARNINGS) * SS-RATE
012100         IF LS-SS-AMOUNT > (LS-GROSS-PAY * SS-RATE)
012200             COMPUTE LS-SS-AMOUNT = LS-GROSS-PAY * SS-RATE
012300         END-IF
012400     ELSE
012500         MOVE 0 TO LS-SS-AMOUNT
012600     END-IF.
012700
012800 500-CALCULATE-MEDICARE.
012900     COMPUTE LS-MEDICARE-AMOUNT = LS-GROSS-PAY * MEDICARE-RATE
013000
013100     IF LS-YTD-EARNINGS + LS-GROSS-PAY > MEDICARE-THRESHOLD
013200         COMPUTE WS-TAXABLE-EARNINGS = 
013300             (LS-YTD-EARNINGS + LS-GROSS-PAY) - MEDICARE-THRESHOLD
013400         IF WS-TAXABLE-EARNINGS > LS-GROSS-PAY
013500             COMPUTE WS-TAXABLE-EARNINGS = LS-GROSS-PAY
013600         END-IF
013700         COMPUTE LS-MEDICARE-AMOUNT = LS-MEDICARE-AMOUNT + 
013800             (WS-TAXABLE-EARNINGS * MEDICARE-ADD-RATE)
013900     END-IF.
014000
014100 600-CALCULATE-TOTAL-TAXES.
014200     COMPUTE LS-NET-TAX = LS-TAX-AMOUNT + LS-SS-AMOUNT + 
014300                         LS-MEDICARE-AMOUNT.
014400
014500 END PROGRAM TAXCALCULATION.
